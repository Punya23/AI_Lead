# =============================================================================
# Geta.ai Lead Pipeline — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- Application ---
APP_NAME=geta-lead-pipeline
APP_ENV=development
DEBUG=true

# --- Database (PostgreSQL) ---
# Async driver for FastAPI
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:postgres@postgres:5432/leads_db
# Sync driver for Celery workers
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@postgres:5432/leads_db

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=leads_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- LLM Provider (Google Gemini) ---
# OPTIONAL: Leave as-is for mock enrichment (keyword-based, no API needed)
# Set a real key for AI-powered enrichment via Gemini
GOOGLE_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=30

# --- Routing Thresholds ---
ROUTING_HIGH_THRESHOLD=70
ROUTING_MEDIUM_THRESHOLD=40

# --- Failure Simulation ---
SIMULATE_FAILURES=false
FAILURE_RATE_LLM_TIMEOUT=0.15
FAILURE_RATE_MALFORMED_RESPONSE=0.10
FAILURE_RATE_DB_ERROR=0.05
FAILURE_RATE_RATE_LIMIT=0.10

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Notifications (leave empty to disable) ---
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# --- Semantic Dedup (ChromaDB) ---
ENABLE_SEMANTIC_DEDUP=true
SEMANTIC_SIMILARITY_THRESHOLD=0.85
CHROMA_PERSIST_DIR=/app/data/chroma

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
